{
  "name": "vibelayer",
  "version": "0.1.2",
  "description": "Framework-independent local-first store, durable mutation queue, sync engine, and conflict middleware.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahamoment-101/VibeLayer.git",
