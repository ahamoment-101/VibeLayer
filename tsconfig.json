{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "vibelayer": ["packages/core/src/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": [
    "packages/**/*.ts",
    "examples/**/*.ts",
    "tests/**/*.ts"
  ]
}
